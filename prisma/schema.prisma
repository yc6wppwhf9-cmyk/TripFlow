generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
  HR
  VENDOR
}

enum Stage {
  PENDING_MANAGER
  PENDING_VENDOR
  COMPLETED
  REJECTED
}

enum BookingType {
  FLIGHT
  HOTEL
  TRAIN
  CAB
  MEAL
  TRIP_PACKAGE
}

model User {
  id               String         @id @default(uuid())
  email            String         @unique
  password         String
  name             String
  phone            String?
  role             Role           @default(EMPLOYEE)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  employee         Employee?      @relation("UserToEmployee")
  managedEmployees Employee[]     @relation("ManagerToEmployees")
  vendor           Vendor?
  notifications    Notification[]
}

model Employee {
  id         String    @id @default(uuid())
  userId     String    @unique
  user       User      @relation("UserToEmployee", fields: [userId], references: [id])
  department String
  managerId  String?
  manager    User?     @relation("ManagerToEmployees", fields: [managerId], references: [id])
  policyId   String?
  policy     Policy?   @relation(fields: [policyId], references: [id])
  bookings   Booking[]

  @@index([userId])
  @@index([managerId])
}

model Vendor {
  id          String    @id @default(uuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id])
  companyName String
  serviceType String
  bookings    Booking[]

  @@index([userId])
}

model Booking {
  id              String      @id @default(uuid())
  employeeId      String
  employee        Employee    @relation(fields: [employeeId], references: [id])
  vendorId        String?
  vendor          Vendor?     @relation(fields: [vendorId], references: [id])
  type            BookingType
  details         Json
  stage           Stage       @default(PENDING_MANAGER)
  cost            Float?
  ticketUrl       String?
  pnr             String?
  receiptUrl      String?
  rejectionReason String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([employeeId])
  @@index([vendorId])
  @@index([stage])
}

model Policy {
  id        String     @id @default(uuid())
  name      String
  rules     Json
  employees Employee[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

// ── Indian Railways own database ─────────────────────────────────────────────

model RailStation {
  code  String     @id         // e.g. "NDLS", "BCT", "MFP"
  name  String                 // e.g. "New Delhi"
  city  String?                // e.g. "Delhi"
  state String?
  zone  String?                // NR, WR, CR, SR, ER, SER, SCR, ECR, NCR, NWR, WCR, NER
  lat   Float?
  lng   Float?
  stops RailStop[]

  @@index([city])
}

model RailTrain {
  id        Int        @id @default(autoincrement())
  trainNo   String     @unique  // e.g. "12951"
  trainName String               // e.g. "Mumbai Rajdhani Express"
  trainType String               // RAJDHANI | SHATABDI | DURONTO | SF | EXP | PASS
  fromCode  String               // origin station code
  toCode    String               // destination station code
  runDays   String               // "Daily" | "Mon,Wed,Fri" | "Except Sun"
  classes   String[]             // ["1A","2A","3A"] or ["SL","3A","2A","1A"]
  stops     RailStop[]

  @@index([fromCode])
  @@index([toCode])
}

model RailStop {
  id            Int         @id @default(autoincrement())
  trainId       Int
  train         RailTrain   @relation(fields: [trainId], references: [id])
  stationCode   String
  station       RailStation @relation(fields: [stationCode], references: [code])
  sequence      Int                    // order of stop on route (1, 2, 3...)
  arrivalTime   String?                // "HH:MM" — null for origin
  departureTime String?                // "HH:MM" — null for terminus
  dayCount      Int         @default(1) // day 1, 2, 3 of the journey
  distanceKm    Int         @default(0) // km from train origin

  @@unique([trainId, sequence])
  @@index([stationCode])
  @@index([trainId])
}
